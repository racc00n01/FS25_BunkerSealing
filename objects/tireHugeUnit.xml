<?xml version="1.0" encoding="utf-8" standalone="no"?>
<!-- Single spawned tire (not listed in shop). Spawned by objects/tireHuge.xml multipleItemPurchase. -->
<!-- REQUIRED: vehicle.base.components.component — without it, Vehicle.lua loads zero components (components[1] nil → .node / .isStatic errors). -->
<vehicle type="pallet" allowPickingUp="true">
    <annotation>Bunker seal tire</annotation>
    <storeData>
        <name>
            <en>Bunker seal tire</en>
            <de>Bunker-Abdichtungsreifen</de>
        </name>
        <!-- Non-zero price helps Vehicle load path use default component init (same as parent shop item). -->
        <price>450</price>
        <showInStore>false</showInStore>
    </storeData>
    <base>
        <typeDesc>OBJECT</typeDesc>
        <filename>objects/tireHuge.i3d</filename>
        <mapHotspot type="NONE"/>
        <supportsPickUp>true</supportsPickUp>
        <size width="2" length="2" height="1.5"/>
        <components>
            <component centerOfMass="0 0 0" solverIterationCount="10" mass="80"/>
        </components>
    </base>
    <!-- Care wheel on component root (matches tireHuge.i3d: first component = tireHuge_component0). -->
    <wheels>
        <wheelConfigurations>
            <wheelConfiguration name="default" price="0" saveId="1">
                <wheels autoRotateBack="false" isCareWheel="true">
                    <wheel dimensions="0.2 0.2 0.2" hasTireTracks="false" isLeft="false" isRight="false">
                        <physics repr="0>" driveNode="0>" linkNode="0>" restLoad="0.01" spring="0" damper="0" frictionScale="1" transRatio="0" rotSpeed="0" />
                    </wheel>
                </wheels>
            </wheelConfiguration>
        </wheelConfigurations>
    </wheels>
    <pallet>
        <objectType>EURO_PALLET</objectType>
    </pallet>
</vehicle>
