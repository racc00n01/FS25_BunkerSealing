<?xml version="1.0" encoding="utf-8" standalone="no"?>
<!-- Shop: Objects tab, buy 1–8 tires (same pattern as base game buyable bales). -->
<vehicle type="multipleItemPurchase">
    <annotation>Bunker seal tire (multi purchase)</annotation>

    <storeData>
        <name>
            <en>Bunker seal tire</en>
            <de>Bunker-Abdichtungsreifen</de>
        </name>
        <specs>
            <weight minValue="0"/>
        </specs>
        <functions>
            <function>$l10n_function_bunkerSealTire</function>
        </functions>
        <image>objects/tireHuge.dds</image>
        <!-- Base price for 1 unit when using tier name="1" price="0" -->
        <price>450</price>
        <lifetime>600</lifetime>
        <allowLeasing>false</allowLeasing>
        <canBeSold>true</canBeSold>
        <rotation>0</rotation>
        <brand>LIZARD</brand>
        <category>MISC</category>
        <vertexBufferMemoryUsage>512</vertexBufferMemoryUsage>
        <indexBufferMemoryUsage>256</indexBufferMemoryUsage>
        <textureMemoryUsage>65536</textureMemoryUsage>
        <instanceVertexBufferMemoryUsage>0</instanceVertexBufferMemoryUsage>
        <instanceIndexBufferMemoryUsage>0</instanceIndexBufferMemoryUsage>
        <financeCategory>PURCHASE_VEHICLES</financeCategory>
        <storeIconRendering>
            <settings cameraXRot="-15" cameraYRot="25"/>
        </storeIconRendering>
        <audioMemoryUsage>0</audioMemoryUsage>
    </storeData>

    <base>
        <typeDesc>OBJECT</typeDesc>
        <filename>$data/objects/multiPurchaseItem/multiPurchaseItem.i3d</filename>
        <size width="2" length="2" height="3.5"/>
        <components>
            <component centerOfMass="0 0 0" solverIterationCount="10" mass="80"/>
        </components>
    </base>

    <!-- Spawn pallet tires (vehicles); not bales — no fillType / baleVariationId -->
    <multipleItemPurchase filename="objects/tireHugeUnit.xml" isVehicle="true">
        <offsets>
            <offset amount="1" offset="0 0 0.35"/>
            <offset amount="5" offset="0 0 0"/>
        </offsets>
        <!-- Shop preview stack (scaled for tire size vs square bales) -->
        <itemPositions>
            <itemPosition position="0 0.35 -0.45" rotation="0 90 0"/>
            <itemPosition position="0 1.05 -0.45" rotation="0 90 0"/>
            <itemPosition position="0 1.75 -0.45" rotation="0 90 0"/>
            <itemPosition position="0 2.45 -0.45" rotation="0 90 0"/>
            <itemPosition position="0 0.35 0.45" rotation="0 90 0"/>
            <itemPosition position="0 1.05 0.45" rotation="0 90 0"/>
            <itemPosition position="0 1.75 0.45" rotation="0 90 0"/>
            <itemPosition position="0 2.45 0.45" rotation="0 90 0"/>
        </itemPositions>
    </multipleItemPurchase>

    <!-- Total price per quantity tier (450 per tire); tier 1 uses storeData.price when price 0 -->
    <multipleItemPurchaseAmountConfigurations>
        <multipleItemPurchaseAmountConfiguration name="1" price="0"/>
        <multipleItemPurchaseAmountConfiguration name="2" price="900"/>
        <multipleItemPurchaseAmountConfiguration name="3" price="1350"/>
        <multipleItemPurchaseAmountConfiguration name="4" price="1800"/>
        <multipleItemPurchaseAmountConfiguration name="5" price="2250"/>
        <multipleItemPurchaseAmountConfiguration name="6" price="2700"/>
        <multipleItemPurchaseAmountConfiguration name="7" price="3150"/>
        <multipleItemPurchaseAmountConfiguration name="8" price="3600"/>
    </multipleItemPurchaseAmountConfigurations>
</vehicle>
